# ============================================================
# 机械手册 RAG 系统配置
# 使用方式：copy .env.example .env，然后填入真实 API Key
# ============================================================

# ── 必填 ──────────────────────────────────────────────────
# 硅基流动 API Key，申请地址：https://cloud.siliconflow.cn
SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 嵌入模型 ───────────────────────────────────────────────
EMBED_MODEL=BAAI/bge-large-zh-v1.5
EMBED_ENDPOINT=https://api.siliconflow.cn/v1/embeddings
EMBED_BATCH_SIZE=4
EMBED_MAX_CHARS=400
EMBED_DIM=1024

# ── LLM ───────────────────────────────────────────────────
LLM_MODEL=deepseek-ai/DeepSeek-R1-0528-Qwen3-8B
LLM_ENDPOINT=https://api.siliconflow.cn/v1/chat/completions
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ── 检索参数 ───────────────────────────────────────────────
TOP_K_TOC=3
TOP_K_BLOCKS=5

# ── 路径 ───────────────────────────────────────────────────
DATA_DIR=./data
CHROMA_DIR=./chroma_db
FRONTEND_DIR=./frontend/dist

# ── ChromaDB Collection 名 ─────────────────────────────────
TOC_COLLECTION_NAME=toc_nodes
BLOCKS_COLLECTION_NAME=semantic_blocks
CHILD_CHUNKS_COLLECTION_NAME=child_chunks
PARENT_BLOCKS_COLLECTION_NAME=parent_blocks
